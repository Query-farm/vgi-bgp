# name: test/sql/read_updates.test
# description: read_updates over the golden BGP4MP fixture (announce/withdraw),
#              plain and gzip, including the message_type split.
# group: [sql]

require-env VGI_BGP_WORKER

statement ok
LOAD vgi;

statement ok
LOAD inet;

statement ok
ATTACH 'bgp' AS bgp (TYPE vgi, LOCATION '${VGI_BGP_WORKER}');

# Announcements vs withdrawals in one stream (the spec's second example).
query TI
SELECT message_type, count(*) FROM bgp.main.read_updates('data/updates.mrt')
GROUP BY 1 ORDER BY 1;
----
announce	2
withdraw	1

# The gzip archive decodes identically (transparent decompression).
query TI
SELECT message_type, count(*) FROM bgp.main.read_updates('data/updates.mrt.gz')
GROUP BY 1 ORDER BY 1;
----
announce	2
withdraw	1

# The withdrawal carries the prefix but no AS path / next hop.
query TII
SELECT (prefix::INET)::VARCHAR, as_path IS NULL, next_hop IS NULL
FROM bgp.main.read_updates('data/updates.mrt')
WHERE message_type = 'withdraw';
----
203.0.113.0/24	true	true

statement ok
DETACH bgp;
